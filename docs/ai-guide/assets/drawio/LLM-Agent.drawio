        <mxCell id="text-many2many" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;strokeColor=none;" value="一个 LLM 可以服务多个 Agent&#xa;一个 Agent 也可以调用多个 LLM" vertex="1">
